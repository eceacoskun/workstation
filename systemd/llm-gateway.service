[Unit]
Description=LLM Gateway (FastAPI, proje bazli auth + token log)
After=network-online.target vllm-qwen.service vllm-embed.service
Wants=vllm-qwen.service vllm-embed.service

[Service]
Type=simple
User=llm
Group=llm
WorkingDirectory=/opt/llm-gateway/gateway
Environment=GATEWAY_CONFIG=/opt/llm-gateway/gateway/config.yaml
Environment=GATEWAY_LOG_DIR=/var/log/llm-gateway
EnvironmentFile=-/opt/llm-gateway/env
ExecStart=/opt/llm-gateway/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8080 --workers 1
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
