# /opt/llm-gateway/env olarak kopyala (systemd EnvironmentFile).

# Gated HF repo'lari icin token
HF_TOKEN=hf_xxx
HUGGING_FACE_HUB_TOKEN=hf_xxx

# Model override (start-qwen.sh / start-embed.sh icinde okunur)
QWEN_MODEL=Qwen/Qwen3-32B
EMBED_MODEL=Qwen/Qwen3-Embedding-4B

# Isteğe bagli: HF cache konumu
# HF_HOME=/opt/hf-cache
